# Enforce LF line endings for files that run on Linux
*.sh    text eol=lf
*.conf  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf

# Binary files — no line ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
